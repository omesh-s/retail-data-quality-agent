# Copy to .env and adjust. Never commit .env.

# --- Gemini / Google GenAI (required for run_day.py, adk web, evaluate --with-llm)
# GOOGLE_API_KEY=
# Or use Vertex / ADC as documented for google-genai.

# --- Companion HTTP API (uvicorn app.main:app)
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8080

# Logging: console | json, or set LOG_CONFIG_FILE to a YAML dictConfig
LOG_LEVEL=INFO
LOG_FORMAT=console
# LOG_CONFIG_FILE=config/logging/console.yaml

# --- Metrics data source
# local_csv (default) | databricks_mcp (scaffold — query not implemented yet)
RETAIL_DATA_SOURCE=local_csv
# RETAIL_METRICS_CSV=

# Databricks MCP (required when RETAIL_DATA_SOURCE=databricks_mcp)
# HTTP JSON-RPC endpoint that supports tools/call (see README for contract)
# DATABRICKS_MCP_SERVER_URL=https://your-mcp-host/mcp
# DATABRICKS_METRICS_CATALOG=retail
# DATABRICKS_METRICS_SCHEMA=metrics
# DATABRICKS_METRICS_TABLE=daily_store_metrics
# DATABRICKS_MCP_TOOL_NAME=execute_sql
# DATABRICKS_MCP_AUTH_TOKEN=
# DATABRICKS_MCP_TIMEOUT_SECONDS=60
# Optional full SQL override instead of SELECT * FROM catalog.schema.table:
# DATABRICKS_METRICS_SQL=SELECT * FROM retail.metrics.daily_store_metrics

# --- Retail pipeline defaults (CLI, ADK tool, daily report)
RETAIL_HISTORY_DAYS=30
RETAIL_Z_THRESHOLD=4.0
RETAIL_GRAIN_MIN_DISTINCT=3
# RETAIL_GRAIN_MIN_AVG=
# RETAIL_TOP_N=

# --- Daily report + Slack
DAILY_REPORT_TOP_N=10
SLACK_ENABLED=false
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_TIMEOUT_SECONDS=10
