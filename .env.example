# Retail Data Quality Agent (MCP-first) — environment configuration
# Copy to .env and edit manually.

# --- LLM / ADK ---
LLM_PROVIDER=googlegenai
LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LITELLM_API_BASE=
# LITELLM_API_KEY=

# --- MCP backend for ADK ---
# Transport mode:
# - stdio: local trusted process boundary (default)
# - sse: remote MCP endpoint over HTTP/SSE (authenticated boundary recommended)
WFM_DQ_MCP_TRANSPORT_FOR_ADK=stdio

# External MCP server script path (paired setup).
# WFM_DQ_MCP_SERVER_PATH_FOR_ADK=C:/path/to/wfm_dq_mcp_server/server.py
# Optional interpreter override for MCP server process.
# WFM_DQ_MCP_PYTHON_FOR_ADK=C:/path/to/wfm_dq_mcp_server/.venv/Scripts/python.exe

# Remote MCP URL for SSE mode (example: http://127.0.0.1:8000/sse)
# WFM_DQ_MCP_SERVER_URL_FOR_ADK=
# Optional bearer token for remote MCP auth
# WFM_DQ_MCP_AUTH_TOKEN_FOR_ADK=
# Require auth token when using SSE mode
WFM_DQ_MCP_REQUIRE_AUTH_FOR_SSE=false

# MCP stdio timeout (seconds)
WFM_DQ_MCP_SERVER_TIMEOUT_FOR_ADK=90
# Optional one-line stderr diagnostics per MCP stdio call (debug only).
MCP_STDIO_DIAGNOSTICS=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
# Optional: path to python logging dictConfig YAML
# LOG_CONFIG_FILE=

# --- Companion HTTP service ---
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8080

# Legacy local CSV/CLI settings have been moved out of the active path.
