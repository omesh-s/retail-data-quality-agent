# Copy to .env or run: python setup_wizard.py
# Wizard writes LLM_PROVIDER + LLM_MODEL (curated id), data source, Slack, scheduler.
# Advanced pipeline keys use defaults unless you opt in during setup.

# --- LLM (run_day summaries; ADK web uses googlegenai + GOOGLE_API_KEY) ---
LLM_PROVIDER=googlegenai
LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LITELLM_API_BASE=
# LITELLM_API_KEY=

# --- HTTP API ---
SERVICE_HOST=127.0.0.1
SERVICE_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Metrics data source: local_csv | databricks_mcp ---
RETAIL_DATA_SOURCE=local_csv
# RETAIL_METRICS_CSV=data/retail_data_quality_sim.csv

# --- Databricks MCP client (HTTP JSON-RPC tools/call; see README) ---
# DATABRICKS_MCP_SERVER_URL=
# DATABRICKS_METRICS_CATALOG=
# DATABRICKS_METRICS_SCHEMA=
# DATABRICKS_METRICS_TABLE=
# DATABRICKS_MCP_TOOL_NAME=execute_sql
# DATABRICKS_MCP_AUTH_TOKEN=
# DATABRICKS_MCP_TIMEOUT_SECONDS=60
# DATABRICKS_METRICS_SQL=

# --- Pipeline defaults (wizard skips unless advanced setup) ---
RETAIL_HISTORY_DAYS=30
RETAIL_Z_THRESHOLD=4.0
RETAIL_GRAIN_MIN_DISTINCT=3
# RETAIL_GRAIN_MIN_AVG=
# RETAIL_TOP_N=

# --- Schema / performance ---
DATA_SCHEMA_PROFILE=retail_default
DATA_USE_PYARROW=true

# --- Daily report + Slack webhook (not a chat bot) ---
DAILY_REPORT_TOP_N=10
# Auto-send when SLACK_ENABLED or DAILY_REPORT_DEFAULT_SEND_SLACK and webhook set
DAILY_REPORT_DEFAULT_SEND_SLACK=false
DAILY_REPORT_ENABLED=false
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
DAILY_REPORT_TIMEZONE=UTC
SLACK_ENABLED=false
# SLACK_WEBHOOK_URL=
SLACK_TIMEOUT_SECONDS=10
